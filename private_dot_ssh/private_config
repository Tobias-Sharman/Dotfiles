Host *
	ForwardAgent no
	AddKeysToAgent no
	Compression no
	ServerAliveInterval 60
	ServerAliveCountMax 3
	HashKnownHosts no
	UserKnownHostsFile ~/.ssh/known_hosts
	ControlMaster no
	ControlPath ~/.ssh/cm-%C
	ControlPersist no
	IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

Host github.com
	HostName github.com
	User git
